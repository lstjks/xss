{
  "version": 2,
  "builds": [
    { "src": "api/**/*.php", "use": "@beyondcode/vercel-php@0.0.4" },
    { "src": "**/*.php", "use": "@beyondcode/vercel-php@0.0.4" }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/static/$1" },
    { "src": "/src/(.*)", "dest": "/src/$1" },
    { "src": "/api/(.*)", "dest": "/api/index.php" },
    { "src": "/(.*)", "dest": "/index.php" }
  ]
}
